{
  "extends": "default",
  "meta": {
    "name": "swival",
    "version": "1.0.0",
    "description": "Swival CLI coding agent (registry-managed). Supersedes the built-in swival profile: adds read access to ~/.config/nono/packages and ~/.config/nono/profiles so symlinked skills resolve inside the sandbox, and write access to ~/.config/nono/profile-drafts so Swival can draft profile extensions when the user agrees to expand access.",
    "author": "Frank Denis <github@pureftpd.org>"
  },
  "groups": {
    "include": [
      "deny_credentials",
      "deny_keychains_macos",
      "deny_keychains_linux",
      "deny_browser_data_macos",
      "deny_browser_data_linux",
      "deny_macos_private",
      "deny_shell_history",
      "deny_shell_configs",
      "system_read_macos",
      "system_read_linux_core",
      "system_write_macos",
      "system_write_linux",
      "user_tools",
      "homebrew_macos",
      "homebrew_linux",
      "dangerous_commands",
      "dangerous_commands_macos",
      "dangerous_commands_linux",
      "python_runtime",
      "node_runtime",
      "user_caches_macos",
      "user_caches_linux",
      "linux_sysfs_read",
      "git_config",
      "unlink_protection"
    ]
  },
  "security": {
    "signal_mode": "isolated",
    "capability_elevation": false
  },
  "filesystem": {
    "allow": [
      "$HOME/.config/swival",
      "$HOME/.local/share/swival",
      "$HOME/.config/nono/profile-drafts"
    ],
    "read": [
      "$HOME/.config/nono/packages",
      "$HOME/.config/nono/profiles"
    ]
  },
  "network": { "block": false },
  "workdir": { "access": "readwrite" },
  "rollback": {
    "exclude_patterns": ["node_modules", "__pycache__", ".swival"],
    "exclude_globs": ["*.pyc"]
  }
}
